{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing name and phone",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"name": "Иван", "phone": "123"},
      "expectedStatus": 400
    },
    {
      "name": "Method not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}
